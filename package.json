{
  "name": "ci_analyzer",
  "version": "7.0.0",
  "description": "Export multiple CI service build data for analyzing.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Kesin11/CIAnalyzer.git"
  },
  "keywords": [
    "CI"
  ],
  "author": "kesin1202000@gmail.com",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/Kesin11/CIAnalyzer/issues"
  },
  "homepage": "https://github.com/Kesin11/CIAnalyzer#readme",
  "bin": {
    "ci_analyzer": "src/index.ts"
  },
  "type": "module",
  "scripts": {
    "prepare": "git config core.hooksPath .githooks || true",
    "start": "node ./src/index.ts",
    "check": "tsc --noEmit",
    "check:watch": "tsc --watch --noEmit",
    "biome:ci": "biome ci .",
    "lint:fix": "biome lint --write --unsafe .",
    "fmt:fix": "biome format --write .",
    "test": "TZ=UTC vitest --run",
    "test:ci": "TZ=UTC vitest --run --coverage",
    "json_schema": "node ./scripts/create_schema.ts",
    "docker": "docker buildx build --load --tag ghcr.io/kesin11/ci_analyzer:latest ."
  },
  "dependencies": {
    "@google-cloud/bigquery": "8.3.1",
    "@google-cloud/storage": "7.21.0",
    "@octokit/plugin-retry": "8.1.0",
    "@octokit/plugin-throttling": "11.0.3",
    "@octokit/rest": "22.0.1",
    "adm-zip": "0.5.18",
    "js-yaml": "5.2.1",
    "junit2json": "3.2.1",
    "lodash-es": "4.18.1",
    "minimatch": "10.2.5",
    "tslog": "4.11.0",
    "undici": "8.7.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@types/adm-zip": "0.5.8",
    "@types/js-yaml": "4.0.9",
    "@types/lodash-es": "4.17.12",
    "@types/node": "24.13.3",
    "@vitest/coverage-v8": "^4.1.10",
    "typescript": "6.0.3",
    "vitest": "4.1.10"
  }
}
